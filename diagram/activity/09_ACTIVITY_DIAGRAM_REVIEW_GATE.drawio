        <!-- 18. a_end_mgr → end_outer (Manajer, straight down) -->
        <mxCell id="e18" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="a_end_mgr" target="end_outer" parent="1">
