          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 5. db1 → s2 (Database→Sistem, cross-lane left) -->
        <mxCell id="e5" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" edge="1" source="db1" target="s2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 6. s2 → m1 (Sistem→Manajer, cross-lane left) -->
        <mxCell id="e6" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" edge="1" source="s2" target="m1" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 7. m1 → d1 (Manajer, straight down) -->
        <mxCell id="e7" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="m1" target="d1" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 8. d1 → m2_yes (Ya, straight down) -->
        <!-- d1 bottom: (245+95, 50+576)=(340,626); m2_yes top: (245+95, 50+598)=(340,648) -->
        <mxCell id="e8" value="Ya" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="d1" target="m2_yes" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 9. d1 → m2_no (Tidak, bypass m2_yes via right waypoints) -->
        <!-- d1 right page: (245+155, 50+546)=(400,596) -->
        <!-- Waypoints: (440,596) in Sistem lane left margin, then down to (440,753) at m2_no right height -->
        <!-- m2_no right page: (245+180, 50+703)=(425,753) -->
        <mxCell id="e9" value="Tidak" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;exitX=1;exitY=0.5;entryX=1;entryY=0.5;" edge="1" source="d1" target="m2_no" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="440" y="596" />
              <mxPoint x="440" y="753" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 10. m2_yes → s4 (Manajer→Sistem, YES path) -->
        <mxCell id="e10" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="m2_yes" target="s4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 11. m2_no → s3 (Manajer→Sistem, NO path) -->
        <mxCell id="e11" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="m2_no" target="s3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 12. s3 → a2 (LOOP BACK: Sistem→Teknisi via left margin waypoints) -->
        <!-- s3 left page: (435+10, 50+722)=(445,772); a2 left page: (55+10, 50+194)=(65,244) -->
        <!-- Waypoints: far left (22,772) then up (22,244) -->
        <mxCell id="e12" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="s3" target="a2" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="22" y="772" />
              <mxPoint x="22" y="244" />
            </Array>
          </mxGeometry>
