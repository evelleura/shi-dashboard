        <mxCell id="e17" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0;entryY=0.5;" edge="1" source="a_end_tek" target="end_outer" parent="1">
