        <!-- 14. db2 → s5 (Database→Sistem) -->
        <mxCell id="e14" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" edge="1" source="db2" target="s5" parent="1">
