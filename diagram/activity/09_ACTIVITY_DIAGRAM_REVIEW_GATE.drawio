  <diagram id="act-review-gate" name="Activity Diagram Review Gate">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="870" pageHeight="1130" background="#FFFFFF" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ACTIVITY DIAGRAM: PELAPORAN PROGRES HARIAN DAN VALIDASI (REVIEW GATE) -->
        <!-- Gambar 3.4 Activity Diagram Pelaporan Progres Harian dan Validasi (Review Gate). -->

        <!-- ===== SWIMLANES ===== -->

        <mxCell id="lane1" value="User (Teknisi)" style="swimlane;startSize=30;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontStyle=1;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="55" y="50" width="190" height="1020" as="geometry" />
        </mxCell>

        <mxCell id="lane2" value="User (Manajer)" style="swimlane;startSize=30;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontStyle=1;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="245" y="50" width="190" height="1020" as="geometry" />
        </mxCell>

        <mxCell id="lane3" value="Sistem" style="swimlane;startSize=30;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontStyle=1;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="435" y="50" width="190" height="1020" as="geometry" />
        </mxCell>

        <mxCell id="lane4" value="Database" style="swimlane;startSize=30;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontStyle=1;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="625" y="50" width="190" height="1020" as="geometry" />
        </mxCell>

        <!-- ===== TEKNISI LANE ===== -->

        <!-- Start: initial node -->
        <mxCell id="start" value="" style="ellipse;aspect=fixed;fillColor=#000000;strokeColor=#000000;strokeWidth=1;" vertex="1" parent="lane1">
          <mxGeometry x="83" y="50" width="24" height="24" as="geometry" />
        </mxCell>

        <!-- A1: Membuka papan Kanban -->
        <mxCell id="a1" value="Membuka Papan Kanban Proyek" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane1">
          <mxGeometry x="10" y="100" width="170" height="44" as="geometry" />
        </mxCell>

        <!-- A2: Menggeser status + unggah foto -->
        <mxCell id="a2" value="Menggeser Status Tugas ke Working On It dan Mengunggah Foto Bukti" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane1">
          <mxGeometry x="10" y="164" width="170" height="60" as="geometry" />
        </mxCell>

        <!-- A_end_tek: Melihat tugas selesai -->
        <mxCell id="a_end_tek" value="Melihat Tugas Selesai di Kanban" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane1">
          <mxGeometry x="10" y="860" width="170" height="40" as="geometry" />
        </mxCell>

        <!-- ===== MANAJER LANE ===== -->

        <!-- M1: Buka detail + tinjau foto -->
        <mxCell id="m1" value="Membuka Detail Tugas dan Meninjau Foto Bukti dari Teknisi" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane2">
          <mxGeometry x="10" y="444" width="170" height="50" as="geometry" />
        </mxCell>

        <!-- D1: Decision - Apakah hasil valid? -->
        <mxCell id="d1" value="Apakah Hasil Pekerjaan Valid?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane2">
          <mxGeometry x="35" y="516" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- M2_yes: Setujui + geser ke Done (YES branch) -->
        <mxCell id="m2_yes" value="Menyetujui dan Menggeser Status Tugas menjadi Done" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane2">
          <mxGeometry x="10" y="598" width="170" height="60" as="geometry" />
        </mxCell>

        <!-- M2_no: Kirim catatan revisi (NO branch) -->
        <mxCell id="m2_no" value="Mengirim Catatan Revisi kepada Teknisi" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane2">
          <mxGeometry x="10" y="678" width="170" height="50" as="geometry" />
        </mxCell>

        <!-- A_end_mgr: Melihat pembaruan selesai -->
        <mxCell id="a_end_mgr" value="Melihat Pembaruan Selesai" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane2">
          <mxGeometry x="10" y="860" width="170" height="40" as="geometry" />
        </mxCell>

        <!-- End: bullseye final node (outer ring) -->
        <mxCell id="end_outer" value="" style="ellipse;aspect=fixed;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;" vertex="1" parent="lane2">
          <mxGeometry x="78" y="920" width="34" height="34" as="geometry" />
        </mxCell>
        <!-- End: bullseye inner filled circle -->
        <mxCell id="end_inner" value="" style="ellipse;aspect=fixed;fillColor=#000000;strokeColor=#000000;strokeWidth=1;" vertex="1" parent="lane2">
          <mxGeometry x="86" y="928" width="18" height="18" as="geometry" />
        </mxCell>

        <!-- ===== SISTEM LANE ===== -->

        <!-- S1: Menerima data pembaruan -->
        <mxCell id="s1" value="Menerima Data Pembaruan Tugas dan File Foto" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane3">
          <mxGeometry x="10" y="234" width="170" height="44" as="geometry" />
        </mxCell>

        <!-- S2: Notifikasi perlu direview -->
        <mxCell id="s2" value="Memunculkan Notifikasi Perlu Direview di Dashboard Manajer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane3">
          <mxGeometry x="10" y="374" width="170" height="54" as="geometry" />
        </mxCell>

        <!-- S4: Proses persetujuan (YES path) -->
        <mxCell id="s4" value="Memproses Persetujuan Tugas Selesai" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane3">
          <mxGeometry x="10" y="628" width="170" height="44" as="geometry" />
        </mxCell>

        <!-- S3: Teruskan notifikasi revisi (NO path) -->
        <mxCell id="s3" value="Meneruskan Notifikasi Revisi ke Teknisi" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane3">
          <mxGeometry x="10" y="700" width="170" height="44" as="geometry" />
        </mxCell>

        <!-- S5: Tampilkan pesan selesai ke kedua aktor -->
        <mxCell id="s5" value="Menampilkan Pesan Tugas Berhasil Diselesaikan ke Kedua Aktor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane3">
          <mxGeometry x="10" y="792" width="170" height="54" as="geometry" />
        </mxCell>

        <!-- ===== DATABASE LANE ===== -->

        <!-- DB1: Simpan progres sementara (cylinder) -->
        <mxCell id="db1" value="(tb_tugas)&#xa;Menyimpan Data Progres Sementara" style="shape=mxgraph.flowchart.database;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane4">
          <mxGeometry x="10" y="304" width="170" height="54" as="geometry" />
        </mxCell>

        <!-- DB2: Update status akhir (cylinder) -->
        <mxCell id="db2" value="(tb_tugas)&#xa;Memperbarui Status Akhir Tugas" style="shape=mxgraph.flowchart.database;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane4">
          <mxGeometry x="10" y="734" width="170" height="54" as="geometry" />
        </mxCell>

        <!-- Caption -->
        <mxCell id="caption" value="Gambar 3.4 Activity Diagram Pelaporan Progres Harian dan Validasi (Review Gate)." style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontStyle=2;fontSize=11;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="55" y="1094" width="760" height="30" as="geometry" />
        </mxCell>

        <!-- ===== EDGES ===== -->

        <!-- 1. start → a1 (Teknisi, straight down) -->
        <mxCell id="e1" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="start" target="a1" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 2. a1 → a2 (Teknisi, straight down) -->
        <mxCell id="e2" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="a1" target="a2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 3. a2 → s1 (Teknisi→Sistem, cross-lane right) -->
        <mxCell id="e3" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="a2" target="s1" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 4. s1 → db1 (Sistem→Database, cross-lane right) -->
