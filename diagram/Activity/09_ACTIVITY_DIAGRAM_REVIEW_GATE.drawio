        </mxCell>

        <!-- A1: Membuka papan Kanban -->
        <mxCell id="a1" value="Membuka Papan Kanban Proyek" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane1">
          <mxGeometry x="8" y="100" width="168" height="40" as="geometry" />
        </mxCell>

        <!-- A2: Menggeser status + upload foto (loop target) -->
