        <mxCell id="m1" value="Membuka Detail Tugas dan Meninjau Foto Bukti dari Teknisi" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane2">
          <mxGeometry x="10" y="380" width="168" height="54" as="geometry" />
