        <mxCell id="note_spi_sys" value="Aturan Status Kesehatan (SPI):
  Hijau : SPI &gt;= 0.95
  Kuning: 0.85 &lt;= SPI &lt; 0.95
  Merah : SPI &lt; 0.85

SPI = (selesai/total) / (hari_terpakai/total_hari)" style="shape=note;size=14;whiteSpace=wrap;html=1;fontSize=11;fontColor=#000000;fillColor=#FFF8DC;strokeColor=#000000;strokeWidth=1;align=left;verticalAlign=top;spacingLeft=6;spacingRight=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="800" y="1350" width="360" height="110" as="geometry" />
        </mxCell>
        <mxCell id="note_computed_sys" value="Status terhitung (computed):
  Overtime     : status=working_on_it
                 AND due_date &lt; hari_ini
  Over Deadline: status=to_do
                 AND due_date &lt; hari_ini" style="shape=note;size=14;whiteSpace=wrap;html=1;fontSize=11;fontColor=#000000;fillColor=#FFF8DC;strokeColor=#000000;strokeWidth=1;align=left;verticalAlign=top;spacingLeft=6;spacingRight=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="1200" y="1350" width="360" height="90" as="geometry" />
        </mxCell>
        <mxCell id="note_phase_sys" value="Siklus dua fase:
  phase=survey -&gt; survey_approved=true
  -&gt; phase=execution
  Hanya manager dapat approve survey." style="shape=note;size=14;whiteSpace=wrap;html=1;fontSize=11;fontColor=#000000;fillColor=#FFF8DC;strokeColor=#000000;strokeWidth=1;align=left;verticalAlign=top;spacingLeft=6;spacingRight=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="1600" y="1350" width="360" height="80" as="geometry" />
        </mxCell>
        <mxCell id="caption" value="&lt;i&gt;Gambar 4.X Class Diagram Sistem Dashboard PT Smart Home Inovasi.&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontStyle=2;fontColor=#000000;" vertex="1" parent="1">
