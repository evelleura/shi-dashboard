        <mxCell id="s4" value="Mengurutkan proyek: Merah → Kuning → Hijau" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="ls">
