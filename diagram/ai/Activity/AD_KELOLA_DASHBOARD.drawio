  <diagram id="ad-kelola-dashboard" name="Activity Diagram Kelola Dashboard">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" background="#FFFFFF" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ═══ LANE: Manajer (x=50, w=290, h=880) ═══ -->
        <!-- abs content top = 70+30 = 100. Abs y of node = 100 + local_y -->
        <mxCell id="lm" value="Manajer" style="swimlane;startSize=30;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontStyle=1;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="50" y="70" width="290" height="880" as="geometry" />
        </mxCell>

        <mxCell id="sm" value="" style="ellipse;aspect=fixed;fillColor=#000000;strokeColor=#000000;strokeWidth=1;" vertex="1" parent="lm">
          <mxGeometry x="133" y="40" width="24" height="24" as="geometry" />
        </mxCell>

        <!-- local y=90, abs center-y=212 [triggers Sistem fetch] -->
        <mxCell id="m1" value="Membuka halaman dashboard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lm">
          <mxGeometry x="60" y="90" width="170" height="44" as="geometry" />
        </mxCell>

        <!-- local y=380, abs center-y=505 [receives rendered dashboard from s5] -->
        <mxCell id="m2" value="Melihat kartu status RAG, grafik progres, dan tabel proyek" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lm">
          <mxGeometry x="60" y="380" width="170" height="60" as="geometry" />
        </mxCell>

        <!-- D1 center local-y = 466+35=501, abs center-y=601 -->
        <mxCell id="d1" value="Ada proyek status merah (kritis)?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lm">
          <mxGeometry x="70" y="466" width="150" height="70" as="geometry" />
        </mxCell>

        <!-- D1 Ya → m3: menganalisis proyek kritis -->
        <mxCell id="m3" value="Menganalisis detail proyek kritis dan notifikasi EWS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lm">
          <mxGeometry x="60" y="562" width="170" height="54" as="geometry" />
        </mxCell>

        <!-- converge: m3 and D1-Tidak both arrive here -->
        <mxCell id="m4" value="Mengambil tindakan korektif terhadap proyek bermasalah" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lm">
          <mxGeometry x="60" y="700" width="170" height="54" as="geometry" />
        </mxCell>

        <mxCell id="m5" value="Memantau progres proyek secara berkala" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lm">
          <mxGeometry x="60" y="780" width="170" height="50" as="geometry" />
        </mxCell>

        <mxCell id="em" value="" style="ellipse;html=1;shape=endState;fillColor=strokeColor;" vertex="1" parent="lm">
          <mxGeometry x="130" y="876" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- ═══ LANE: Sistem (x=340, w=430, h=880) ═══ -->
        <mxCell id="ls" value="Sistem" style="swimlane;startSize=30;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontStyle=1;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="340" y="70" width="430" height="880" as="geometry" />
        </mxCell>

        <!-- local y=90, abs center-y=212 ← ALIGNS with m1 → horizontal arrow -->
