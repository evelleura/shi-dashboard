        <mxCell id="s2" value="Menghitung nilai SPI tiap proyek (EV / PV)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="ls">
          <mxGeometry x="130" y="160" width="170" height="50" as="geometry" />
