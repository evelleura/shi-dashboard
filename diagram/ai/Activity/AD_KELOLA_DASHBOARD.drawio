        <!-- local y=380, abs center-y=510 ← ALIGNS with m2 → horizontal arrow -->
        <mxCell id="s5" value="Menampilkan dashboard: kartu RAG, grafik, tabel, dan notifikasi EWS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="ls">
          <mxGeometry x="130" y="380" width="170" height="60" as="geometry" />
