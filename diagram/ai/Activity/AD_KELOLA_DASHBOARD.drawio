        <mxCell id="em6" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="m4" target="m5" parent="lm"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="em7" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="m5" target="em" parent="lm"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ═══ EDGES within Sistem ═══ -->
        <mxCell id="es1" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="s1" target="s2" parent="ls"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="es2" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="s2" target="s3" parent="ls"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="es3" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="s3" target="s4" parent="ls"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="es4" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="s4" target="s5" parent="ls"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ═══ CROSS-LANE edges (parent="1") ═══ -->

        <!-- m1 right → s1 left: abs center-y=212 → horizontal -->
        <mxCell id="ec1" style="endArrow=classic;html=1;rounded=0;strokeColor=#000000;strokeWidth=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="m1" target="s1" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- s5 left → m2 right: abs center-y≈510 → horizontal -->
