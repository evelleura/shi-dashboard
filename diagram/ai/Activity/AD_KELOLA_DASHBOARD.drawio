        <mxCell id="start_m" value="" style="ellipse;aspect=fixed;fillColor=#000000;strokeColor=#000000;strokeWidth=1;" vertex="1" parent="lane_m">
          <mxGeometry x="133" y="40" width="24" height="24" as="geometry" />
