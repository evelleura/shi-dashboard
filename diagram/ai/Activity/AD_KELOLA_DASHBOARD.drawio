        <!-- ═══ EDGES within Manajer ═══ -->
        <mxCell id="em1" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="sm" target="m1" parent="lm"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="em2" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="m2" target="d1" parent="lm"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- D1 Ya → m3 straight down -->
        <mxCell id="em3" value="Ya" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="d1" target="m3" parent="lm"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- D1 Tidak → m4: right-margin bypass within lm (w=290) -->
        <mxCell id="em4" value="Tidak" style="endArrow=classic;html=1;rounded=0;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;exitX=1;exitY=0.5;entryX=1;entryY=0.5;" edge="1" source="d1" target="m4" parent="lm">
