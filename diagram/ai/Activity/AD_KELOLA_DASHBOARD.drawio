        </mxCell>

        <!-- Sistem lane -->
        <mxCell id="lane_s" value="Sistem" style="swimlane;startSize=30;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontStyle=1;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="340" y="70" width="420" height="860" as="geometry" />
        </mxCell>

        <mxCell id="s1" value="Mengambil data semua proyek aktif" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane_s">
          <mxGeometry x="125" y="90" width="170" height="40" as="geometry" />
        </mxCell>

        <mxCell id="s2" value="Menghitung nilai SPI tiap proyek (EV / PV)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane_s">
          <mxGeometry x="125" y="155" width="170" height="50" as="geometry" />
        </mxCell>

        <mxCell id="s3" value="Menetapkan status RAG: Merah / Kuning / Hijau" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane_s">
          <mxGeometry x="125" y="225" width="170" height="50" as="geometry" />
        </mxCell>

        <mxCell id="s4" value="Mengurutkan proyek: Merah → Kuning → Hijau" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane_s">
          <mxGeometry x="125" y="295" width="170" height="50" as="geometry" />
        </mxCell>

        <mxCell id="s5" value="Menampilkan kartu RAG, grafik, dan tabel proyek" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane_s">
          <mxGeometry x="125" y="365" width="170" height="50" as="geometry" />
        </mxCell>

        <mxCell id="s6" value="Menampilkan notifikasi EWS untuk proyek kritis" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane_s">
          <mxGeometry x="125" y="445" width="170" height="50" as="geometry" />
        </mxCell>

        <mxCell id="s7" value="Menghitung ulang SPI saat ada perubahan tugas" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane_s">
          <mxGeometry x="125" y="625" width="170" height="50" as="geometry" />
        </mxCell>

        <!-- Within-Manajer edges -->
        <mxCell id="em1" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="start_m" target="m1" parent="lane_m"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="em2" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="m2" target="D1" parent="lane_m"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="em3" value="Ya" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="D1" target="m3" parent="lane_m"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- D1 Tidak: exits right down to m4 (skipping m3) -->
        <mxCell id="em4" value="Tidak" style="endArrow=classic;html=1;rounded=0;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;exitX=1;exitY=0.5;entryX=1;entryY=0.5;" edge="1" source="D1" target="m4" parent="lane_m">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="265" y="370" />
              <mxPoint x="265" y="635" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- m3 → m4 -->
        <mxCell id="em5" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="m3" target="m4" parent="lane_m"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="em6" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="m4" target="m5" parent="lane_m"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="em7" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="m5" target="end_m" parent="lane_m"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Within-Sistem edges -->
        <mxCell id="es1" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="s1" target="s2" parent="lane_s"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="es2" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="s2" target="s3" parent="lane_s"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="es3" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="s3" target="s4" parent="lane_s"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="es4" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="s4" target="s5" parent="lane_s"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="es5" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="s5" target="s6" parent="lane_s"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Cross-lane edges (parent="1") -->
        <!-- m1 → s1 -->
        <mxCell id="ec1" style="endArrow=classic;html=1;rounded=0;strokeColor=#000000;strokeWidth=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="m1" target="s1" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- s5 → m2 (render dashboard → manajer sees it) -->
        <mxCell id="ec2" style="endArrow=classic;html=1;rounded=0;strokeColor=#000000;strokeWidth=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" edge="1" source="s5" target="m2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- s6 → m3 (EWS → manajer sees notification) -->
        <mxCell id="ec3" style="endArrow=classic;html=1;rounded=0;strokeColor=#000000;strokeWidth=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" edge="1" source="s6" target="m3" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- m4 → s7 (manajer action triggers SPI recalc) -->
        <mxCell id="ec4" style="endArrow=classic;html=1;rounded=0;strokeColor=#000000;strokeWidth=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="m4" target="s7" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- s7 → s1 (recalculation loops back to fetch) via right margin -->
        <mxCell id="ec5" style="endArrow=classic;html=1;rounded=0;strokeColor=#000000;strokeWidth=1;exitX=1;exitY=0.5;entryX=1;entryY=0.5;" edge="1" source="s7" target="s1" parent="lane_s">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="395" y="650" />
              <mxPoint x="395" y="110" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="caption" value="Gambar 3.8 Activity Diagram Pemantauan Dashboard dan Early Warning System." style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontStyle=2;fontSize=11;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="50" y="956" width="720" height="30" as="geometry" />
