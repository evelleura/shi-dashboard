        <mxCell id="m2" value="Melihat kartu status RAG dan grafik progres" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane_m">
          <mxGeometry x="60" y="260" width="170" height="50" as="geometry" />
        </mxCell>

        <mxCell id="D1" value="Ada proyek status merah (kritis)?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane_m">
          <mxGeometry x="70" y="335" width="150" height="70" as="geometry" />
        </mxCell>

        <mxCell id="m3" value="Melihat notifikasi Early Warning System" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane_m">
          <mxGeometry x="60" y="430" width="170" height="50" as="geometry" />
        </mxCell>

        <mxCell id="m4" value="Menganalisis data dan mengambil tindakan" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane_m">
          <mxGeometry x="60" y="610" width="170" height="50" as="geometry" />
        </mxCell>

        <mxCell id="m5" value="Memantau progres proyek secara berkala" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="lane_m">
          <mxGeometry x="60" y="690" width="170" height="50" as="geometry" />
