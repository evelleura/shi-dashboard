        <mxCell id="s3" value="Menetapkan status RAG tiap proyek" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;" vertex="1" parent="ls">
          <mxGeometry x="130" y="236" width="170" height="44" as="geometry" />
