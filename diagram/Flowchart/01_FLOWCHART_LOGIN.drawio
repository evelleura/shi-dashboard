  <diagram id="fc-login" name="Flowchart Login dan Autentikasi">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" background="#FFFFFF" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- FLOWCHART LOGIN DAN AUTENTIKASI -->
        <!-- Gambar 4.1 Flowchart Login dan Autentikasi -->

        <!-- 1. Mulai -->
        <mxCell id="start" value="Mulai" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="265" y="20" width="160" height="44" as="geometry" />
        </mxCell>

        <!-- 2. Buka Halaman Login -->
        <mxCell id="p1" value="Buka Halaman Login" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="265" y="104" width="160" height="44" as="geometry" />
        </mxCell>

        <!-- 3. Input Email dan Password -->
        <mxCell id="io1" value="Input Email dan Password" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="265" y="188" width="160" height="44" as="geometry" />
        </mxCell>

        <!-- 4. Decision: Kredensial Valid? -->
        <mxCell id="d1" value="Kredensial Valid?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="265" y="272" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- 5. Tampil Pesan Error (cabang N - kiri) -->
        <mxCell id="perr" value="Tampil Pesan Error" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="50" y="202" width="155" height="44" as="geometry" />
        </mxCell>

        <!-- 6. Cek Role Pengguna -->
        <mxCell id="p2" value="Cek Role Pengguna" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="265" y="382" width="160" height="44" as="geometry" />
        </mxCell>

        <!-- 7. Decision: Role = Teknisi? -->
        <mxCell id="d2" value="Role = Teknisi?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="265" y="466" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- 8. Redirect /my-dashboard (cabang Y - kanan) -->
        <mxCell id="ioR" value="Redirect /my-dashboard" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="470" y="476" width="175" height="44" as="geometry" />
        </mxCell>

