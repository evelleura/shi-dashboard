# ---------------------------------------------------------------------------
# Template for project_ta_dian_putri_iswandi/.env
#
# Usage:
#   cp scripts/env.template .env
#   # then edit .env, fill in the <...> placeholders
#
# .env is gitignored. Never commit it.
# ---------------------------------------------------------------------------

# === Deploy metadata (read by scripts/deploy_fly.py, never pushed as secrets) ===
FLY_APP_NAME=shi-dashboard
FLY_GITHUB_REPO=shi-dashboard-deploy
FLY_VOLUME_NAME=shi_data
FLY_REGION=sin
FLY_VOLUME_SIZE_GB=1

# Optional Cloudflare-fronted domain (kosongkan kalau pakai *.fly.dev)
CF_DOMAIN=

# === Fly.io auth (skip browser login) ============================================
# Generate:
#   fly auth token                            # token akun penuh
#   fly tokens create deploy -a <APP_NAME>    # token scoped per-app (lebih aman)
#
# Paste tokennya satu baris (boleh ada spasi, jangan dikutip):
FLY_API_TOKEN=<paste-token-baru-disini>

# === App secrets (di-push otomatis via `fly secrets set`) ========================
# Tambah baris sebanyak yg kamu perlu. Semua KEY=VALUE yg TIDAK diawali
# FLY_ atau CF_ akan dianggap secret dan ikut ke Fly.io machine.
#
# Contoh untuk project ini (sesuaikan):
DATABASE_URL=postgres://user:pass@host:5432/dbname
JWT_SECRET=<random-string-min-32-chars>
NODE_ENV=production
