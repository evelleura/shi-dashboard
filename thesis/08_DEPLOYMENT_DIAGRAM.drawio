        <mxCell id="deploy-note" value="&lt;b&gt;Deployment Modes:&lt;/b&gt;&#10;• &lt;b&gt;Development:&lt;/b&gt; All nodes on localhost (python run.py)&#10;• &lt;b&gt;Staging:&lt;/b&gt; Separate servers, same network&#10;• &lt;b&gt;Production:&lt;/b&gt; Load-balanced, replicated DB, backups&#10;&#10;&lt;b&gt;Key Properties:&lt;/b&gt;&#10;• Zero-dependency setup (portable PostgreSQL auto-download)&#10;• Cross-platform: Windows, macOS, Linux&#10;• All API traffic authenticated via JWT&#10;• SQL injection protected via parameterized queries&#10;• File uploads stored on local disk (not cloud)" style="shape=note;whiteSpace=wrap;html=1;size=14;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;spacing=5;rounded=0" vertex="1" parent="1">
          <mxGeometry x="580" y="860" width="380" height="190" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>