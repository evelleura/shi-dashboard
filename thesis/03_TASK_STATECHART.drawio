<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-04-15T12:00:00.000Z" agent="5.0" version="24.0.0" type="device">
  <diagram id="statechart-diagram" name="Task Statechart Diagram">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" background="#FFFFFF" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ======================== -->
        <!-- INITIAL STATE -->
        <!-- ======================== -->
        <mxCell id="initial" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;strokeWidth=1" vertex="1" parent="1">
          <mxGeometry x="100" y="185" width="20" height="20" as="geometry" />
        </mxCell>

        <!-- ======================== -->
        <!-- STATE: TO_DO -->
        <!-- ======================== -->
        <mxCell id="state-todo" value="TO_DO&#xa;&#xa;entry / Tugas dibuat" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=11;fontColor=#000000;align=center;verticalAlign=middle;spacingTop=0" vertex="1" parent="1">
          <mxGeometry x="230" y="155" width="170" height="80" as="geometry" />
        </mxCell>

        <!-- ======================== -->
        <!-- STATE: WORKING_ON_IT -->
        <!-- ======================== -->
        <mxCell id="state-working" value="WORKING_ON_IT&#xa;&#xa;do / Teknisi mengerjakan tugas" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=11;fontColor=#000000;align=center;verticalAlign=middle;spacingTop=0" vertex="1" parent="1">
          <mxGeometry x="550" y="155" width="210" height="80" as="geometry" />
        </mxCell>

        <!-- ======================== -->
        <!-- STATE: DONE -->
        <!-- ======================== -->
        <mxCell id="state-done" value="DONE&#xa;&#xa;entry / SPI dihitung ulang" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=11;fontColor=#000000;align=center;verticalAlign=middle;spacingTop=0" vertex="1" parent="1">
          <mxGeometry x="870" y="155" width="170" height="80" as="geometry" />
        </mxCell>

        <!-- ======================== -->
        <!-- FINAL STATE -->
        <!-- ======================== -->
        <mxCell id="final-outer" value="" style="ellipse;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1" vertex="1" parent="1">
          <mxGeometry x="1100" y="178" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="final-inner" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;strokeWidth=1" vertex="1" parent="1">
          <mxGeometry x="1107" y="185" width="16" height="16" as="geometry" />
        </mxCell>

        <!-- ======================== -->
        <!-- TRANSITIONS -->
        <!-- ======================== -->

        <!-- Initial -> TO_DO -->
        <mxCell id="trans-init-todo" value="" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;fontColor=#000000;fontSize=10" edge="1" parent="1" source="initial" target="state-todo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- TO_DO -> WORKING_ON_IT -->
        <mxCell id="trans-todo-working" value="[Teknisi mulai mengerjakan]" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;fontColor=#000000;fontSize=10;html=0" edge="1" parent="1" source="state-todo" target="state-working">
          <mxGeometry relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- WORKING_ON_IT -> DONE -->
        <mxCell id="trans-working-done" value="[Manajer menyetujui penyelesaian]" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;fontColor=#000000;fontSize=10;html=0" edge="1" parent="1" source="state-working" target="state-done">
          <mxGeometry relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- DONE -> Final -->
        <mxCell id="trans-done-final" value="" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1;fontColor=#000000;fontSize=10" edge="1" parent="1" source="state-done" target="final-outer">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ======================== -->
        <!-- COMPUTED OVERLAY STATES -->
        <!-- ======================== -->

        <!-- OVERTIME (dashed box) -->
        <mxCell id="overlay-overtime" value="OVERTIME&#xa;(status = WORKING_ON_IT&#xa;AND due_date &lt; TODAY)" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;dashed=1;dashPattern=8 4;align=center;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="370" y="380" width="200" height="70" as="geometry" />
        </mxCell>

        <!-- Dashed arrow from WORKING_ON_IT to OVERTIME -->
        <mxCell id="link-working-overtime" value="" style="endArrow=none;dashed=1;dashPattern=4 4;strokeColor=#000000;strokeWidth=1" edge="1" parent="1" source="state-working" target="overlay-overtime">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- OVER_DEADLINE (dashed box) -->
        <mxCell id="overlay-overdeadline" value="OVER_DEADLINE&#xa;(status = TO_DO&#xa;AND due_date &lt; TODAY)" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;dashed=1;dashPattern=8 4;align=center;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="100" y="380" width="200" height="70" as="geometry" />
        </mxCell>

        <!-- Dashed arrow from TO_DO to OVER_DEADLINE -->
        <mxCell id="link-todo-overdeadline" value="" style="endArrow=none;dashed=1;dashPattern=4 4;strokeColor=#000000;strokeWidth=1" edge="1" parent="1" source="state-todo" target="overlay-overdeadline">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ======================== -->
        <!-- NOTE BOX -->
        <!-- ======================== -->
        <mxCell id="note" value="Catatan: Status OVERTIME dan OVER_DEADLINE&#xa;dihitung secara otomatis oleh sistem berdasarkan&#xa;tanggal, bukan disimpan di database." style="shape=note;whiteSpace=wrap;html=0;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=10;fontColor=#000000;align=left;verticalAlign=middle;size=15;spacingLeft=5" vertex="1" parent="1">
          <mxGeometry x="620" y="370" width="310" height="80" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
