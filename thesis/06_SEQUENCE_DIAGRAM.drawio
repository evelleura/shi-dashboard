        <mxCell id="msg6_14" value="14: Update UI, show success toast notification" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="304" y="860" as="sourcePoint" />
            <mxPoint x="95" y="860" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Note: Role-based gate -->
        <mxCell id="note6_1" value="ROLE-BASED GATE:&#xa;Only managers can mark tasks &quot;done&quot;.&#xa;Technicians can only set status to&#xa;&quot;to_do&quot; or &quot;working_on_it&quot;.&#xa;This enforces the review/approval workflow." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=5;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="680" y="310" width="280" height="80" as="geometry" />
        </mxCell>

        <!-- Note: Dashboard refresh -->
        <mxCell id="note6_2" value="Dashboard auto-refreshes via&#xa;TanStack Query cache invalidation.&#xa;All dashboard queries re-fetch&#xa;after task mutation completes." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="100" y="910" width="250" height="70" as="geometry" />
        </mxCell>

      </root>
