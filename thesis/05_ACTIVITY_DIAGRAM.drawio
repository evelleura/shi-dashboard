        <mxCell id="p2-ev" value="Calculate Earned Value (EV)&#xa;EV = completed_tasks / total_tasks" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
