        <mxCell id="p2-e8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p2-ev" target="p2-join" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="325" y="590" />
              <mxPoint x="450" y="590" />
